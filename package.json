{
  "name": "cambrian",
  "version": "1.0.0",
  "description": "Darwin Protocol base workspace scaffold",
  "main": "dist/apps/orchestrator/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:axl": "npm run build && node dist/scripts/testAxlIntegration.js",
    "test:axl:e2e": "npm run build && node dist/scripts/testAxlBroadcastE2E.js",
    "start:backend": "npm run build && node dist/backend/server.js",
    "seed:population": "npm run build && node dist/scripts/seedPopulation.js",
    "spawn:agents": "npm run build && node dist/scripts/spawnAgents.js",
    "spawn:axl-nodes": "npm run build && node dist/scripts/spawnAxlNodes.js",
    "run:generation": "npm run build && node dist/scripts/runGeneration.js",
    "start:arena": "npm run build && node dist/scripts/startArena.js",
    "cleanup": "npm run build && node dist/scripts/cleanup.js",
    "test": "npm run check && npm run test:axl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apurvborhade/Cambrian.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Apurvborhade/Cambrian/issues"
  },
  "homepage": "https://github.com/Apurvborhade/Cambrian#readme",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.7.5",
    "@supabase/supabase-js": "^2.105.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.1",
    "express": "^5.1.0",
    "ws": "^8.20.0"
  }
}
